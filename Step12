def sanitize_folder_name(name):
    cleaned = re.sub(r'[\\/*?:"<>|]', "", name)
    return cleaned.strip()

def extract_file_number(file_name):
    match = re.search(r'\d+', file_name)
    return int(match.group()) if match else None

def split_land_project_files(txt_files):
    start_idx = None
    for idx, file_name in enumerate(txt_files):
        if "землеустроительный проект" in file_name.lower():
            start_idx = idx
            break

    if start_idx is None:
        return txt_files, None

    end_idx = None
    for idx in range(start_idx, len(txt_files)):
        if "бланк заказа" in txt_files[idx].lower():
            end_idx = idx
            break

    if end_idx is None:
        logging.warning("⚠️ Найден 'Землеустроительный проект', но не найден 'Бланк заказа'. Диапазон не вырезан из анализа Gemma.")
        return txt_files, None

    project_files = txt_files[start_idx:end_idx]

    pdf_numbers = [extract_file_number(file_name) for file_name in project_files]
    if any(number is None for number in pdf_numbers):
        logging.warning("⚠️ Не удалось определить номера PDF для блока 'Землеустроительный проект'. Диапазон не вырезан из анализа Gemma.")
        return txt_files, None

    manual_folder = {
        "name": "Землеустроительный проект",
        "content": [
            {
                "name": "Землеустроительный проект.pdf",
                "pdfs": pdf_numbers
            }
        ]
    }
    gemma_files = txt_files[:start_idx] + txt_files[end_idx:]

    logging.info(
        f"📌 Блок 'Землеустроительный проект' найден: PDF {pdf_numbers}. "
        "Этот диапазон не будет отправлен Gemma и будет добавлен в JSON вручную."
    )
