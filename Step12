    txt_files = [f for f in os.listdir(TEMP_DIR) if f.endswith('.txt')]
    txt_files.sort(key=lambda x: int(re.search(r'\d+', x).group()) if re.search(r'\d+', x) else 0)

    if not txt_files:
        logging.error("❌ Папка temp пуста. Выполнение невозможно.")
        return None

    txt_files, manual_folder = split_land_project_files(txt_files)

    if not txt_files and manual_folder:
        return save_structure_json({"files": [manual_folder]})

    docs_info = ""
    for f_name in txt_files:
        file_path = TEMP_DIR / f_name
        with open(file_path, 'r', encoding='utf-8') as f:
            text = f.read().strip()
            
        # Передаем начало и конец текста для выявления "шапок" и "подписей"
        if len(text) > 1000:
            short_text = text[:500] + "\n...[ТЕКСТ СОКРАЩЕН]...\n" + text[-500:]
        else:
            short_text = text
            
        docs_info += f"ФАЙЛ: {f_name}\nТЕКСТ:\n{short_text}\n\n"

    system_prompt = """Ты архитектор данных. Твоя задача — проанализировать тексты страниц и сгруппировать их в строгий JSON.

ПРАВИЛА АНАЛИЗА И СШИВАНИЯ (КРИТИЧЕСКИ ВАЖНО):
1. Анализ текста (Разделяй и властвуй):
   - Если файлы идут подряд и относятся к одному типу (например, четыре файла "Заявление"), ВНИМАТЕЛЬНО ИЗУЧИ ТЕКСТ.
   - СШИВАЙ их в один массив (например, "pdfs": [1, 2]), ТОЛЬКО если текст логически перетекает (на первой странице нет подписи, а на второй нет новой "шапки" Кому/От кого).
   - РАЗДЕЛЯЙ их на разные документы (разные объекты внутри "content"), если видишь начало нового документа: новую шапку (ФИО, реквизиты), дату, новую печать или повторное слово "ЗАЯВЛЕНИЕ" в начале страницы. В таком случае делай два разных документа, например "pdfs": [1, 2] и "pdfs": [3, 4].
2. Жесткое именование:
   - Значение "name" для папки ДОЛЖНО СТРОГО совпадать с названием самого документа. Никаких выдуманных названий! Если файлы называются "Заявление", папка должна называться "Заявление".

Верни ТОЛЬКО валидный JSON без markdown-разметки. Формат:
{
    "files": [
        {
            "name": "Точное_название_документа",
            "content": [
                {
                    "name": "Название_документа.pdf",
                    "pdfs": [1, 2]
                },
                {
                    "name": "Название_документа.pdf",
                    "pdfs": [3, 4]
                }
            ]
        }
    ]
}"""

    payload = {
        "model": "gemma4",
        "messages": [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": docs_info}
        ],
        "temperature": 0.0,
        "max_tokens": 4000
    }

    try:
        headers = {"Authorization": f"Bearer {GEMMA_KEY}", "Content-Type": "application/json"}
        resp = session.post(URL, headers=headers, json=payload, verify=False, timeout=120)
        resp.raise_for_status()
        answer = resp.json()["choices"][0]["message"]["content"].strip()
        
        # Очистка от маркдауна
        if answer.startswith("```json"):
            answer = answer.replace("```json\n", "", 1)
        if answer.endswith("```"):
            answer = answer[:-3]
            
        json_data = json.loads(answer)
        if manual_folder:
            json_data.setdefault("files", []).append(manual_folder)

        return save_structure_json(json_data)

    except json.JSONDecodeError:
        logging.error(f"❌ Ошибка парсинга JSON. Ответ модели:\n{answer}")
        return None
    except Exception as e:
        logging.error(f"❌ Ошибка генерации структуры: {e}")
        return None
def main():
    INPUT_DIR.mkdir(exist_ok=True)
    OUTPUT_DIR.mkdir(exist_ok=True)
    TEMP_DIR.mkdir(exist_ok=True)
    
    valid_filenames = [f for f in os.listdir(INPUT_DIR) if os.path.isfile(os.path.join(INPUT_DIR, f)) and not f.startswith('.')]
    if not valid_filenames:
        logging.error(f"❌ Папка {INPUT_DIR.name} пуста.")
        return

    valid_filenames.sort(key=lambda x: int(re.search(r'\d+', x).group()) if re.search(r'\d+', x) else 0)
    total_files = len(valid_filenames)

    allowed_types = []
    if EXCEL_FILE.exists():
        try:
            df = pd.read_excel(EXCEL_FILE)
            column_name = "Название документа"
            if column_name in df.columns:
                raw_list = df[column_name].dropna().astype(str).str.strip().unique().tolist()
                allowed_types = [t for t in raw_list if t and not t.startswith("№")]
        except Exception as e:
            logging.error(f"⚠️ Ошибка чтения Excel файла: {e}")

    # --- ПРОВЕРКА КЭША В ПАПКЕ TEMP ---
    temp_files = [f for f in os.listdir(TEMP_DIR) if f.endswith('.txt')]
    
    if len(temp_files) == total_files and total_files > 0:
        logging.info("♻️ [КЭШ АКТИВЕН] Обнаружены готовые слепки для всех файлов.")
        logging.info("⏩ Этап 1 (OCR) и Этап 2 (Классификация) пропущены.")
    else:
        # Если количество файлов не совпадает, очищаем temp для чистого старта
        if temp_files:
            logging.info("🧹 Обнаружены неполные/старые данные в temp. Очистка папки...")
            for f in temp_files:
                os.remove(TEMP_DIR / f)

        logging.info(f"🚀 ЗАПУСК ЭТАПОВ 1 И 2: Обработка {total_files} файлов...")
        for idx, f_name in enumerate(valid_filenames, 1):
            f_path = INPUT_DIR / f_name
            
            # Аппаратная задержка
            time.sleep(3) 
            
            logging.info(f"⚙️ Обработка [{idx}/{total_files}]: {f_name}")
            
            # ЭТАП 1: OCR
            try:
                extracted_text = ocr_image_to_text(str(f_path))
                if not extracted_text.strip():
                    extracted_text = "[ГРАФИЧЕСКИЙ ДОКУМЕНТ: ТЕКСТ ОТСУТСТВУЕТ]"
            except Exception as e:
                logging.error(f"Ошибка чтения OCR для {f_name}: {e}")
                extracted_text = "[ОШИБКА РАСПОЗНАВАНИЯ]"

            # ЭТАП 2: Gemma (Название)
            doc_name = analyze_document_by_image(str(f_path), allowed_types)
            
            # Запись слепка
            safe_filename = sanitize_folder_name(f"{idx} {doc_name}")
            txt_filepath = TEMP_DIR / f"{safe_filename}.txt"
            
            with open(txt_filepath, 'w', encoding='utf-8') as f:
                f.write(extracted_text)

        logging.info("✅ ЭТАПЫ 1 И 2 ЗАВЕРШЕНЫ. Тексты сохранены в папке temp.")
    
    # ЭТАП 3: Анализ структуры
    json_structure = generate_structure_json()
    
    if json_structure:
        logging.info("✅ ПЛАН СОСТАВЛЕН. Запускаю сборку PDF по structure.json...")
        try:
            json_to_docs.main()
            logging.info("✅ PDF успешно собраны в папку result.")
        except Exception as e:
