def add_folder_to_structure(json_data, folder):
    folder_name = folder.get("name", "").strip()
    if not folder_name:
        return

    for existing_folder in json_data.setdefault("files", []):
        if existing_folder.get("name") == folder_name:
            existing_folder.setdefault("content", []).extend(folder.get("content", []))
            return

    json_data.setdefault("files", []).append(folder)

def get_first_pdf_number(item):
    numbers = []

    if "pdfs" in item:
        numbers = item.get("pdfs", [])
    else:
        for document in item.get("content", []):
            numbers.extend(document.get("pdfs", []))

    return min(numbers) if numbers else 10**9

def sort_structure_by_pdf_numbers(json_data):
    for folder in json_data.get("files", []):
        folder.get("content", []).sort(key=get_first_pdf_number)

    json_data.get("files", []).sort(key=get_first_pdf_number)

def split_act_span_files(txt_files):
    act_positions = [
        idx for idx, file_name in enumerate(txt_files)
        if "акт на земельный участок" in file_name.lower()
    ]

    if len(act_positions) < 2:
        return txt_files, []

    start_idx = act_positions[0]
    end_idx = act_positions[-1]
    act_span_files = txt_files[start_idx:end_idx + 1]
    qwen_files = txt_files[:start_idx] + txt_files[end_idx + 1:]
    pdf_numbers = [extract_file_number(file_name) for file_name in act_span_files]

    logging.info(f"📌 Диапазон актов вынесен в отдельный AI-разбор: PDF {pdf_numbers}")
    return qwen_files, act_span_files

def get_file_as_base64(file_path):
    if str(file_path).lower().endswith('.pdf'):
        doc = fitz.open(file_path)
        page = doc.load_page(0)
        pix = page.get_pixmap(matrix=fitz.Matrix(2, 2))
        img_bytes = pix.tobytes("jpeg")
        doc.close()
        return base64.b64encode(img_bytes).decode('utf-8')
    else:
        with open(file_path, "rb") as f:
            return base64.b64encode(f.read()).decode('utf-8')

# ЭТАП 1: Извлечение текста
def ocr_image_to_text(file_path):
    img_b64 = get_file_as_base64(file_path)
    payload = {
        "model": "gemma4",
        "messages": [{"role": "user", "content": [
            {"type": "text", "text": "Извлеки весь текст из этого изображения. Верни СТРОГО ТОЛЬКО текст, без каких-либо вводных слов, комментариев или форматирования."},
            {"type": "image_url", "image_url": {"url": f"data:image/jpeg;base64,{img_b64}"}}
        ]}],
        "temperature": 0.0,
        "max_tokens": 3000
    }
    headers = {"Authorization": f"Bearer {GEMMA_KEY}", "Content-Type": "application/json"}
    resp = session.post(URL, headers=headers, json=payload, verify=False, timeout=60)
    resp.raise_for_status()
    return resp.json()["choices"][0]["message"]["content"]

# ЭТАП 2: Классификация (выбор названия)
def analyze_document_by_image(file_path, types_list):
    img_b64 = get_file_as_base64(file_path)
    if types_list:
        numbered_types = [f"{i+1}. {t}" for i, t in enumerate(types_list)]
        types_str = "\n".join(numbered_types)
        system_prompt = (
            f"Ты строгий визуальный классификатор документов. Перед тобой список разрешенных категорий из Excel:\n{types_str}\n\n"
            f"Внимательно посмотри на изображение документа и определи его тип.\n"
            f"Учитывай казахский язык (ӨТІНІШ -> Заявление). Если это чертеж/схема без текста — выбери подходящую категорию.\n"
            f"В качестве ответа верни ТОЛЬКО ЦИФРУ номера пункта."
        )
    else:
        system_prompt = "Посмотри на картинку и определи тип документа. Верни только одно-два слова на русском языке."

    payload = {
        "model": "gemma4",
        "messages": [{"role": "user", "content": [
            {"type": "text", "text": system_prompt},
            {"type": "image_url", "image_url": {"url": f"data:image/jpeg;base64,{img_b64}"}}
        ]}],
        "temperature": 0.0,
        "max_tokens": 5  
    }
    
    try:
        headers = {"Authorization": f"Bearer {GEMMA_KEY}", "Content-Type": "application/json"}
        resp = session.post(URL, headers=headers, json=payload, verify=False, timeout=45)
        resp.raise_for_status()
        raw_answer = resp.json()["choices"][0]["message"]["content"].strip()
        match = re.search(r'\d+', raw_answer)
        if types_list and match:
            index = int(match.group(0)) - 1
            if 0 <= index < len(types_list):
                return types_list[index]
        return "НЕИЗВЕСТНО"
    except Exception as e:
        logging.error(f"Ошибка визуальной классификации: {e}")
        return "ОШИБКА"

def process_input_file(idx, total_files, file_name, allowed_types):
    file_path = INPUT_DIR / file_name
    logging.info(f"⚙️ Обработка [{idx}/{total_files}]: {file_name}")

    try:
        extracted_text = ocr_image_to_text(str(file_path))
        if not extracted_text.strip():
            extracted_text = "[ГРАФИЧЕСКИЙ ДОКУМЕНТ: ТЕКСТ ОТСУТСТВУЕТ]"
    except Exception as e:
        logging.error(f"Ошибка чтения OCR для {file_name}: {e}")
        extracted_text = "[ОШИБКА РАСПОЗНАВАНИЯ]"

    doc_name = analyze_document_by_image(str(file_path), allowed_types)
    safe_filename = sanitize_folder_name(f"{idx} {doc_name}")

    return idx, safe_filename, extracted_text

def get_temp_document_name(file_name):
    name = Path(file_name).stem
    name = re.sub(r'^\d+\s*', '', name).strip()
    return name or Path(file_name).stem

def shorten_document_text(text):
    text = text.strip()
    if len(text) > 1000:
        return text[:500] + "\n...[ТЕКСТ СОКРАЩЕН]...\n" + text[-500:]

    return text

def build_docs_info(file_names):
    docs_info = ""

    for file_name in file_names:
        file_path = TEMP_DIR / file_name
        with open(file_path, 'r', encoding='utf-8') as f:
            text = f.read()

        docs_info += f"ФАЙЛ: {file_name}\nТЕКСТ:\n{shorten_document_text(text)}\n\n"

    return docs_info

def clean_model_json_answer(answer):
    answer = answer.strip()
    if answer.startswith("```json"):
        answer = answer.replace("```json\n", "", 1)
    if answer.startswith("```"):
        answer = answer.replace("```\n", "", 1)
    if answer.endswith("```"):
        answer = answer[:-3]

    return answer.strip()

def get_choice_text(response_json):
    choice = response_json["choices"][0]
    message = choice.get("message", {})
    content = message.get("content")
    if content:
        return content

    reasoning_content = message.get("reasoning_content")
    if reasoning_content:
        return reasoning_content

    return None

def generate_folder_json(folder_name, file_names):
    docs_info = build_docs_info(file_names)
    system_prompt = f"""Ты архитектор данных. Ты анализируешь только один тип документа: "{folder_name}".

Твоя задача — решить, какие страницы этого типа должны быть отдельными PDF, а какие надо сшить вместе.

ПРАВИЛА:
1. Верни JSON только для ОДНОЙ папки.
2. Значение "name" верхнего объекта всегда строго "{folder_name}". Не меняй и не придумывай название папки.
3. Не создавай массив "files" и не создавай несколько папок.
4. В "content" добавляй отдельные документы этого типа:
   - СШИВАЙ подряд идущие файлы в один "pdfs", если текст логически продолжается.
   - РАЗДЕЛЯЙ на разные объекты "content", если видишь начало нового документа: новую шапку, ФИО, реквизиты, дату, печать или повторное название документа.
5. "name" внутри "content" должен быть названием PDF для этого документа. Обычно используй "{folder_name}.pdf".

Верни ТОЛЬКО валидный JSON без markdown-разметки. Формат:
{{
    "name": "{folder_name}",
    "content": [
        {{
            "name": "{folder_name}.pdf",
            "pdfs": [1, 2]
        }},
        {{
            "name": "{folder_name}.pdf",
            "pdfs": [3]
        }}
    ]
}}"""

    payload = {
        "model": "qwen3-6",
        "messages": [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": docs_info}
        ],
        "temperature": 0.0,
        "max_tokens": 25000
    }

    headers = {"Authorization": f"Bearer {QWEN_API_KEY}", "Content-Type": "application/json"}
    resp = session.post(URL, headers=headers, json=payload, verify=False, timeout=300)
    resp.raise_for_status()

    raw_answer = get_choice_text(resp.json())
    if not raw_answer:
        raise ValueError(f"Пустой ответ модели для группы '{folder_name}'")

    answer = clean_model_json_answer(raw_answer)
    folder_data = json.loads(answer)

    if "files" in folder_data:
        files = folder_data.get("files", [])
        if len(files) != 1:
            raise ValueError(f"Модель вернула {len(files)} папок для группы {folder_name}")
        folder_data = files[0]

    folder_data["name"] = folder_name
    return folder_data

def analyze_act_span_files(file_names):
    docs_info = build_docs_info(file_names)
    system_prompt = """Ты архитектор данных. Ты анализируешь непрерывный диапазон файлов от первого до последнего файла с названием "Акт на земельный участок".

Внутри диапазона могут быть:
- один или несколько документов "Акт на земельный участок";
- файлы с другими названиями, которые могут быть вложением/продолжением акта;
- файлы с другими названиями, которые НЕ относятся к акту и должны вернуться в дальнейший разбор по своему названию.

Твоя задача — определить только состав актов. Не создавай папки для других документов.

ПРАВИЛА:
1. Если файл с другим названием логически относится к акту между страницами акта, включай его в "pdfs" этого акта.
2. Если файл с другим названием НЕ относится к акту, добавь его номер в "return_pdfs".
3. По содержанию реши, это один акт с вложениями/продолжениями или несколько разных актов.
4. Каждый объект в массиве "content" — это один отдельный итоговый PDF с актом.
5. Если страницы относятся к одному акту, помести их в один объект "content" с общим "pdfs".
6. Если это несколько разных актов, верни несколько объектов "content".
7. Каждый номер файла из входа должен быть либо в одном из "content[].pdfs", либо в "return_pdfs".
8. Не создавай папки и не решай названия для документов, которые не относятся к акту.

Верни ТОЛЬКО валидный JSON без markdown-разметки. Формат:
{
    "content": [
        {
            "name": "Акт на земельный участок.pdf",
            "pdfs": [57, 58, 59]
        },
        {
            "name": "Акт на земельный участок.pdf",
            "pdfs": [62]
        }
    ],
    "return_pdfs": [
        60,
        61
    ]
}"""

    payload = {
        "model": "qwen3-6",
        "messages": [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": docs_info}
        ],
        "temperature": 0.0,
        "max_tokens": 25000
    }

    headers = {"Authorization": f"Bearer {QWEN_API_KEY}", "Content-Type": "application/json"}
    resp = session.post(URL, headers=headers, json=payload, verify=False, timeout=300)
    resp.raise_for_status()

    raw_answer = get_choice_text(resp.json())
    if not raw_answer:
        raise ValueError("Пустой ответ модели для диапазона актов")

    answer = clean_model_json_answer(raw_answer)
    act_data = json.loads(answer)

    file_by_number = {
        extract_file_number(file_name): file_name
        for file_name in file_names
        if extract_file_number(file_name) is not None
    }
    input_numbers = set(file_by_number)
    act_numbers = set()
    content = []

    for document in act_data.get("content", []):
        pdf_numbers = [
            number for number in document.get("pdfs", [])
            if number in input_numbers
        ]
        if not pdf_numbers:
            continue

        act_numbers.update(pdf_numbers)
        content.append({
            "name": document.get("name") or "Акт на земельный участок.pdf",
            "pdfs": pdf_numbers
        })

    return_numbers = {
        number for number in act_data.get("return_pdfs", [])
        if number in input_numbers
    }
    missing_numbers = input_numbers - act_numbers - return_numbers
    return_numbers.update(missing_numbers)

    act_folder = None
    if content:
        act_folder = {
            "name": "Акт на земельный участок",
            "content": content
        }

    returned_files = [
        file_by_number[number]
        for number in sorted(return_numbers)
        if number in file_by_number
    ]

    return act_folder, returned_files

