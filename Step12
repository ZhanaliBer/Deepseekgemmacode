# ЭТАП 3: Анализ структуры на основе текста
def generate_structure_json():
    logging.info("🧠 ЭТАП 3: Анализ текста и генерация JSON-структуры...")
    
    txt_files = [f for f in os.listdir(TEMP_DIR) if f.endswith('.txt')]
    txt_files.sort(key=lambda x: int(re.search(r'\d+', x).group()) if re.search(r'\d+', x) else 0)

    if not txt_files:
        logging.error("❌ Папка temp пуста. Выполнение невозможно.")
        return None

    try:
        txt_files, manual_folder = split_land_project_files(txt_files)

        txt_files, act_span_files = split_act_span_files(txt_files)
        act_folder = None
        if act_span_files:
            logging.info(f"🧠 ЭТАП 3: отдельный разбор диапазона актов ({len(act_span_files)} файлов)")
            act_folder, returned_files = analyze_act_span_files(act_span_files)
            txt_files = sorted(
                txt_files + returned_files,
                key=lambda x: extract_file_number(x) or 0
            )

        if not txt_files and (manual_folder or act_folder):
            json_data = {"files": []}
            if act_folder:
                add_folder_to_structure(json_data, act_folder)
            if manual_folder:
                add_folder_to_structure(json_data, manual_folder)
            return save_structure_json(json_data)

        grouped_files = {}
        for file_name in txt_files:
            folder_name = get_temp_document_name(file_name)
            grouped_files.setdefault(folder_name, []).append(file_name)

        json_data = {"files": []}

        for folder_name, file_names in grouped_files.items():
            logging.info(f"🧠 ЭТАП 3: группа '{folder_name}' ({len(file_names)} файлов)")
            folder_data = generate_folder_json(folder_name, file_names)
            add_folder_to_structure(json_data, folder_data)

        if act_folder:
            add_folder_to_structure(json_data, act_folder)

        if manual_folder:
            add_folder_to_structure(json_data, manual_folder)

        return save_structure_json(json_data)

    except json.JSONDecodeError:
        logging.error("❌ Ошибка парсинга JSON в одной из групп этапа 3.")
        return None
    except Exception as e:
        logging.error(f"❌ Ошибка генерации структуры: {e}")
        return None
def main():
    INPUT_DIR.mkdir(exist_ok=True)
    OUTPUT_DIR.mkdir(exist_ok=True)
    TEMP_DIR.mkdir(exist_ok=True)
    
    valid_filenames = [f for f in os.listdir(INPUT_DIR) if os.path.isfile(os.path.join(INPUT_DIR, f)) and not f.startswith('.')]
    if not valid_filenames:
        logging.error(f"❌ Папка {INPUT_DIR.name} пуста.")
        return

    valid_filenames.sort(key=lambda x: int(re.search(r'\d+', x).group()) if re.search(r'\d+', x) else 0)
    total_files = len(valid_filenames)

    allowed_types = []
    if EXCEL_FILE.exists():
        try:
            df = pd.read_excel(EXCEL_FILE)
            column_name = "Название документа"
            if column_name in df.columns:
                raw_list = df[column_name].dropna().astype(str).str.strip().unique().tolist()
                allowed_types = [t for t in raw_list if t and not t.startswith("№")]
        except Exception as e:
            logging.error(f"⚠️ Ошибка чтения Excel файла: {e}")

    # --- ПРОВЕРКА КЭША В ПАПКЕ TEMP ---
    temp_files = [f for f in os.listdir(TEMP_DIR) if f.endswith('.txt')]
    
    if len(temp_files) == total_files and total_files > 0:
        logging.info("♻️ [КЭШ АКТИВЕН] Обнаружены готовые слепки для всех файлов.")
        logging.info("⏩ Этап 1 (OCR) и Этап 2 (Классификация) пропущены.")
    else:
        # Если количество файлов не совпадает, очищаем temp для чистого старта
        if temp_files:
            logging.info("🧹 Обнаружены неполные/старые данные в temp. Очистка папки...")
            for f in temp_files:
                os.remove(TEMP_DIR / f)

        logging.info(f"🚀 ЗАПУСК ЭТАПОВ 1 И 2: Обработка {total_files} файлов в {MAX_WORKERS} воркеров...")
        tasks = [
            (idx, file_name)
            for idx, file_name in enumerate(valid_filenames, 1)
        ]

        with ThreadPoolExecutor(max_workers=MAX_WORKERS) as executor:
            futures = [
                executor.submit(process_input_file, idx, total_files, file_name, allowed_types)
                for idx, file_name in tasks
            ]

            for future in as_completed(futures):
                idx, safe_filename, extracted_text = future.result()
                txt_filepath = TEMP_DIR / f"{safe_filename}.txt"

                with open(txt_filepath, 'w', encoding='utf-8') as f:
                    f.write(extracted_text)

                logging.info(f"💾 Слепок сохранен [{idx}/{total_files}]: {txt_filepath.name}")

        logging.info("✅ ЭТАПЫ 1 И 2 ЗАВЕРШЕНЫ. Тексты сохранены в папке temp.")
    
    # ЭТАП 3: Анализ структуры
    json_structure = generate_structure_json()
    
    if json_structure:
        logging.info("✅ ПЛАН СОСТАВЛЕН. Запускаю сборку PDF по structure.json...")
        try:
            json_to_docs.main()
            logging.info("✅ PDF успешно собраны в папку result.")
        except Exception as e:
            logging.error(f"❌ Ошибка сборки PDF: {e}")
    else:
        logging.error("❌ Остановка выполнения: не удалось получить структуру от нейросети.")

if __name__ == "__main__":
    main()
